.env.sh
.log

# Terraform
**/.terraform/*          # provider plugins / module cache
*.tfstate                # state can contain secrets — never commit
*.tfstate.*
*.tfstate.backup
.terraform.tfstate.lock.info
crash.log
crash.*.log
*.tfvars                 # may hold sensitive values; tfvars.example stays tracked
*.tfvars.json
override.tf              # local-only overrides
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — commit it.