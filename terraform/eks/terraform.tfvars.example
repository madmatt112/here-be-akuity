# Copy to terraform.tfvars and adjust. The EKS root only needs AWS credentials
# (profile/role) for the target account; no secrets live here.

# Optional overrides (defaults shown):
# kubernetes_version = "1.30"
# node_instance_type = "t3.medium"

# eks_clusters defaults to four clusters (dev+prod in us-west-1 and us-east-1).
# Override the whole map here if you want a different set, e.g.:
# eks_clusters = {
#   "eks-us-west-1-dev"  = { vpc_cidr = "10.0.0.0/16", region = "us-west-1", env = "dev" }
#   "eks-us-west-1-prod" = { vpc_cidr = "10.1.0.0/16", region = "us-west-1", env = "prod" }
# }
